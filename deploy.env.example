# Copy this file to deploy.local.env and fill in your real server details.
# deploy.local.env is gitignored and never committed.

# SSH host, e.g. an alias defined in ~/.ssh/config so no hostname is ever
# written to this repo.
DEPLOY_HOST=webhost

# Absolute or ~-relative path to the doc root on the server.
DEPLOY_PATH=~/html/example.com
